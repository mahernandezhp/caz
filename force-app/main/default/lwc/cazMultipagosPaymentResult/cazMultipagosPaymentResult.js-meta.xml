<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>Multipagos - Resultado del Pago</masterLabel>
    <description>Procesa la respuesta de Multipagos BBVA en las páginas de retorno del Experience Cloud y muestra el resultado al usuario.</description>
    <targets>
        <target>lightningCommunity__Page</target>
        <target>lightningCommunity__Default</target>
        <target>lightning__RecordPage</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightningCommunity__Default">
            <property name="homeUrl" type="String" label="URL de retorno al portal" default="/" />
            <property name="ordersUrl" type="String" label="URL de lista de órdenes" default="/my-orders" />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>