<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>Multipagos - Formulario de Pago</masterLabel>
    <description>Prepara y envía el formulario POST hacia Multipagos BBVA para una Order.</description>
    <targets>
        <target>lightning__RecordPage</target>
        <target>lightningCommunity__Page</target>
        <target>lightningCommunity__Default</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__RecordPage">
            <objects>
                <object>Order</object>
            </objects>
        </targetConfig>
        <targetConfig targets="lightningCommunity__Default">
            <property name="recordId" type="String" label="Order ID" default="{!recordId}" />
            <property name="buttonLabel" type="String" label="Texto del botón" default="Pagar con Multipagos" />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>