<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>false</active>
    <allowRecall>false</allowRecall>
    <allowedSubmitters>
        <submitter>CAZ_Distribuidores</submitter>
        <type>group</type>
    </allowedSubmitters>
    <allowedSubmitters>
        <type>owner</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>CaseNumber</field>
        <field>Status</field>
        <field>CAZ_MotivoDevolucion__c</field>
        <field>CAZ_ImporteDevolucion__c</field>
        <field>CAZ_NumeroCuentaBancaria__c</field>
        <field>CAZ_ComprobanteReferencia__c</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>true</allowDelegate>
        <approvalActions>
            <action>
                <name>CAZ_FU_Status_PorAtender</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>CAZ_FU_FechaEnvioTesoreria</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>CAZ_FU_Owner_Tesoreria</name>
                <type>FieldUpdate</type>
            </action>
        </approvalActions>
        <assignedApprover>
            <approver>
                <name>CreditoCobranza</name>
                <type>queue</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <description>Revisión de Crédito y Cobranza. Al aprobar se genera la provisión en JDE (pendiente integración) y se envía a Tesorería.</description>
        <label>Etapa 1 - Crédito y Cobranza</label>
        <name>Etapa_1_Credito_y_Cobranza</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
        <rejectionActions>
            <action>
                <name>CAZ_FU_Status_Rechazado</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>CAZ_EA_Rechazo_Devolucion</name>
                <type>Alert</type>
            </action>
        </rejectionActions>
    </approvalStep>
    <approvalStep>
        <allowDelegate>true</allowDelegate>
        <approvalActions>
            <action>
                <name>CAZ_FU_Status_EnProceso</name>
                <type>FieldUpdate</type>
            </action>
        </approvalActions>
        <assignedApprover>
            <approver>
                <name>Tesoreria</name>
                <type>queue</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <description>Gestión de Tesorería. Al aprobar, Tesorería gestiona la devolución bancaria y confirma el depósito vía Quick Action.</description>
        <label>Etapa 2 - Tesorería</label>
        <name>Etapa_2_Tesoreria</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
        <rejectionActions>
            <action>
                <name>CAZ_FU_Status_Rechazado</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>CAZ_EA_Rechazo_Devolucion</name>
                <type>Alert</type>
            </action>
        </rejectionActions>
    </approvalStep>
    <description>Proceso de aprobación de 2 etapas para solicitudes de devolución. Etapa 1: Crédito y Cobranza. Etapa 2: Tesorería.</description>
    <enableMobileDeviceAccess>false</enableMobileDeviceAccess>
    <entryCriteria>
        <criteriaItems>
            <field>Case.Status</field>
            <operation>equals</operation>
            <value>Borrador</value>
        </criteriaItems>
    </entryCriteria>
    <finalApprovalRecordLock>false</finalApprovalRecordLock>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <initialSubmissionActions>
        <action>
            <name>CAZ_EA_Confirmacion_Recepcion</name>
            <type>Alert</type>
        </action>
    </initialSubmissionActions>
    <label>Aprobación Devolución</label>
    <recordEditability>AdminOrCurrentApprover</recordEditability>
    <showApprovalHistory>true</showApprovalHistory>
</ApprovalProcess>
