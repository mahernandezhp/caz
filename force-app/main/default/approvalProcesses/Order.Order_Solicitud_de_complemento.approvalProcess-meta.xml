<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>true</active>
    <allowRecall>false</allowRecall>
    <allowedSubmitters>
        <type>owner</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>OrderNumber</field>
        <field>Owner</field>
        <field>CAZ_Capacidad_de_retiro__c</field>
        <field>EffectiveDate</field>
        <field>CAZ_Motivo_reprogramacion__c</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>true</allowDelegate>
        <approvalActions>
            <action>
                <name>CAZ_Order_1ra_T</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>CAZ_SComplemento_aprobado</name>
                <type>Alert</type>
            </action>
            <action>
                <name>Order_Status_Autorizado</name>
                <type>FieldUpdate</type>
            </action>
        </approvalActions>
        <assignedApprover>
            <approver>
                <name>CAZ_Aprobador_OrderNueva</name>
                <type>queue</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <criteriaItems>
                <field>Order.Status</field>
                <operation>equals</operation>
                <value>Draft</value>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>Solicitud Inicial</label>
        <name>Solicitud_Inicial</name>
        <rejectionActions>
            <action>
                <name>CAZ_SComplemento_rechazado</name>
                <type>Alert</type>
            </action>
        </rejectionActions>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <approvalActions>
            <action>
                <name>CAZ_Order_1ra_T</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>CAZ_SComplemento_aprobado</name>
                <type>Alert</type>
            </action>
            <action>
                <name>Order_Status_Autorizado</name>
                <type>FieldUpdate</type>
            </action>
        </approvalActions>
        <assignedApprover>
            <approver>
                <type>userHierarchyField</type>
            </approver>
        </assignedApprover>
        <entryCriteria>
            <criteriaItems>
                <field>Order.Status</field>
                <operation>equals</operation>
                <value>Rechazado</value>
            </criteriaItems>
        </entryCriteria>
        <label>Nuevo Intento</label>
        <name>Nuevo_Intento</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
        <rejectionActions>
            <action>
                <name>CAZ_SComplemento_rechazado</name>
                <type>Alert</type>
            </action>
            <action>
                <name>Order_Status_Rechazado</name>
                <type>FieldUpdate</type>
            </action>
        </rejectionActions>
    </approvalStep>
    <description>Proceso de aprobación para pedidos nuevos.</description>
    <enableMobileDeviceAccess>false</enableMobileDeviceAccess>
    <entryCriteria>
        <booleanFilter>(1 OR 2) AND 3</booleanFilter>
        <criteriaItems>
            <field>Order.Status</field>
            <operation>equals</operation>
            <value>Draft</value>
        </criteriaItems>
        <criteriaItems>
            <field>Order.Status</field>
            <operation>equals</operation>
            <value>Rechazado</value>
        </criteriaItems>
        <criteriaItems>
            <field>Order.CAZ_Listado_de_Productos__c</field>
            <operation>greaterThan</operation>
            <value>0</value>
        </criteriaItems>
    </entryCriteria>
    <finalApprovalRecordLock>true</finalApprovalRecordLock>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <label>Order Solicitud de complemento</label>
    <nextAutomatedApprover>
        <useApproverFieldOfRecordOwner>false</useApproverFieldOfRecordOwner>
        <userHierarchyField>Manager</userHierarchyField>
    </nextAutomatedApprover>
    <processOrder>3</processOrder>
    <recordEditability>AdminOrCurrentApprover</recordEditability>
    <showApprovalHistory>false</showApprovalHistory>
</ApprovalProcess>
