<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>true</active>
    <allowRecall>false</allowRecall>
    <allowedSubmitters>
        <type>owner</type>
    </allowedSubmitters>
    <allowedSubmitters>
        <submitter>cruzazul@capptus.com</submitter>
        <type>user</type>
    </allowedSubmitters>
    <allowedSubmitters>
        <submitter>mario.q@capptus.com.cazs</submitter>
        <type>user</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>OrderNumber</field>
        <field>Owner</field>
        <field>CAZ_Capacidad_de_retiro__c</field>
        <field>EffectiveDate</field>
        <field>CAZ_Motivo_reprogramacion__c</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>true</allowDelegate>
        <approvalActions>
            <action>
                <name>CAZ_Order_1ra_plT</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>CAZ_Order_1ra_T</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>CAZ_SComplemento_aprobado</name>
                <type>Alert</type>
            </action>
        </approvalActions>
        <assignedApprover>
            <approver>
                <name>CAZ_Aprobador_OrderNueva</name>
                <type>queue</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <criteriaItems>
                <field>Order.Status</field>
                <operation>equals</operation>
                <value>Borrador</value>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>RejectRecord</ifCriteriaNotMet>
        <label>Solicitud Inicial</label>
        <name>Solicitud_Inicial</name>
        <rejectionActions>
            <action>
                <name>CAZ_Order_1ra_F</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>CAZ_Order_1ra_plF</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>CAZ_SComplemento_rechazado</name>
                <type>Alert</type>
            </action>
        </rejectionActions>
    </approvalStep>
    <description>Proceso para aprobar una Orden que no ha sido aprobada. Una vez aprobada, se usara el Proceso de aprobación para solicitar reprogramaciones</description>
    <emailTemplate>unfiled$public/CAZ_PdeA_NuevaOrden</emailTemplate>
    <enableMobileDeviceAccess>false</enableMobileDeviceAccess>
    <entryCriteria>
        <booleanFilter>1 AND (2 OR 3)</booleanFilter>
        <criteriaItems>
            <field>Order.CAZ_Listado_de_Productos__c</field>
            <operation>greaterThan</operation>
            <value>0</value>
        </criteriaItems>
        <criteriaItems>
            <field>Order.CAZ_Estado__c</field>
            <operation>equals</operation>
            <value>Borrador</value>
        </criteriaItems>
        <criteriaItems>
            <field>Order.CAZ_Estado__c</field>
            <operation>equals</operation>
            <value>Rechazado</value>
        </criteriaItems>
    </entryCriteria>
    <finalApprovalRecordLock>true</finalApprovalRecordLock>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <label>CAZ_Order_1ra_vez</label>
    <nextAutomatedApprover>
        <useApproverFieldOfRecordOwner>false</useApproverFieldOfRecordOwner>
        <userHierarchyField>Manager</userHierarchyField>
    </nextAutomatedApprover>
    <processOrder>1</processOrder>
    <recordEditability>AdminOrCurrentApprover</recordEditability>
    <showApprovalHistory>false</showApprovalHistory>
</ApprovalProcess>
