    <rules>
        <fullName>CAZ_WR_Notificar_Devolucion_Completada</fullName>
        <actions>
            <name>CAZ_EA_Devolucion_Completada</name>
            <type>Alert</type>
        </actions>
        <active>true</active>
        <criteriaItems>
            <field>Case.Status</field>
            <operation>equals</operation>
            <value>Completado</value>
        </criteriaItems>
        <description>CAZ - Envía email al distribuidor cuando la devolución es completada</description>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
