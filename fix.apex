List<CAZ_SolicitudDevolucion__Share> shares = new List<CAZ_SolicitudDevolucion__Share>(); for(CAZ_SolicitudDevolucion__c c : [SELECT Id, OwnerId, CreatedById FROM CAZ_SolicitudDevolucion__c WHERE Owner.Type = 'Queue']) { CAZ_SolicitudDevolucion__Share shareRec = new CAZ_SolicitudDevolucion__Share(); shareRec.ParentId = c.Id; shareRec.UserOrGroupId = c.CreatedById; shareRec.AccessLevel = 'Edit'; shareRec.RowCause = Schema.CAZ_SolicitudDevolucion__Share.RowCause.Manual; shares.add(shareRec); } Database.insert(shares, false);
